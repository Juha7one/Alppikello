# StackCP / cPanel Node.js Helper
Options +FollowSymLinks
RewriteEngine On

# Redirect all requests to the Node.js server (local port)
# Huom: Tämä vaatii, että palvelin tukee Passenger- tai vastaavaa moduulia.
RewriteRule ^$ http://127.0.0.1:3000/ [P,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]
